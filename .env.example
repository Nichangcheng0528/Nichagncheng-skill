# CRM Recording Analysis - Environment Variables
# Copy this file to .env and fill in your real credentials
# .env is in .gitignore and will NOT be uploaded to GitHub

# CRM 2.0 Login
CRM_USERNAME=<YOUR_CRM_USERNAME>
CRM_PASSWORD=<YOUR_CRM_PASSWORD>

# Aliyun DashScope API (ASR + LLM)
DASHSCOPE_API_KEY=<YOUR_DASHSCOPE_API_KEY>
